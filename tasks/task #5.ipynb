   "source": [
    "# Собственные значения и вектора матрицы"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "##### Нахождение собственного значения и вектора матрицы"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Собственные значения:\n",
      "[18.58872344 10.          4.41127656]\n",
      "\n",
      "Собственные векторы:\n",
      "[[-5.17333201e-01  7.07106781e-01  4.82043939e-01]\n",
      " [ 6.81713077e-01 -2.67339966e-17  7.31619628e-01]\n",
      " [-5.17333201e-01 -7.07106781e-01  4.82043939e-01]]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "a = np.array([[11, -5, 1], [-5, 11, -5], [1, -5, 11]])\n",
    "eigenvalues, eigenvectors = np.linalg.eig(a)\n",
    "\n",
    "print(\"Собственные значения:\")\n",
    "print(eigenvalues)\n",
    "\n",
    "print(\"\\nСобственные векторы:\")\n",
    "print(eigenvectors)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "##### Нормы собственных векторов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Норма собственного вектора для λ = 18.588723439378928, есть 1.0\n",
      "Норма собственного вектора для λ = 10.000000000000004, есть 1.0\n",
      "Норма собственного вектора для λ = 4.411276560621089, есть 0.9999999999999998\n"
     ]
    }
   ],
   "source": [
    "m = len(eigenvalues)\n",
    "\n",
    "for i in range(m):\n",
    "    print(f'Норма собственного вектора для λ = {eigenvalues[i]}, есть {np.dot(eigenvectors[:, i], eigenvectors[:, i])}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "##### Проверим найденные собственные значения\n",
    "\n",
    "$$A \\cdot x = \\lambda \\cdot x$$\n",
    "\n",
    "$$(A - \\lambda I) \\cdot x = 0$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "---\n",
      "Проверка собственного значения λ = 18.588723439378928\n",
      "Детерминант матрицы A - λI = -1.8307965147909585e-12\n",
      "(A - λI)x = [ 7.99360578e-15 -1.15463195e-14  6.21724894e-15]\n",
      "---\n",
      "Проверка собственного значения λ = 10.000000000000004\n",
      "Детерминант матрицы A - λI = 1.705302565824236e-13\n",
      "(A - λI)x = [-2.86393218e-15  2.19371205e-15  2.24309373e-15]\n",
      "---\n",
      "Проверка собственного значения λ = 4.411276560621089\n",
      "Детерминант матрицы A - λI = -1.2409458881321551e-13\n",
      "(A - λI)x = [-8.88178420e-16  8.88178420e-16 -2.22044605e-15]\n"
     ]
    
