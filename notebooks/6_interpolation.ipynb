    "xd = np.linspace(-1., 1., 5)\n",
    "yd = np.arcsinh(30*xd)\n",
    "\n",
    "x = np.linspace(-1., 1., 20)\n",
    "\n",
    "n = len(x)\n",
    "\n",
    "y = np.zeros((n, 2))\n",
    "k = cs.curvatures(xd, yd)\n",
    "\n",
    "for i in range(n):\n",
    "    y[i, 0] = nv.polynom(xd, yd, x[i])\n",
    "    y[i, 1] = cs.polynom(xd, yd, k, x[i])\n",
    "\n",
    "plt.plot(xd, yd, 'o', x, y[:, 0], '-', x, y[:, 1], '--')\n",
    "plt.xlabel('x')\n",
    "plt.legend(['Data', 'Neville', 'Cubic spline'], loc='lower right')\n"
   ]
